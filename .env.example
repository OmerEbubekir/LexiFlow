# =============================================================
# LearnLanguage — Ortam Değişkenleri Şablonu
# =============================================================
# Bu dosyayı kopyalayın ve ".env" olarak kaydedin, sonra
# gerçek değerlerle doldurun:
#
#   cp .env.example .env
#
# ⚠️  .env dosyasını ASLA Git'e eklemeyin!
#     .gitignore dosyanızda ".env" satırının olduğundan emin olun.
# =============================================================


# -------------------------------------------------------------
# PostgreSQL Veritabanı
# -------------------------------------------------------------
POSTGRES_DB=LearnLanguageDb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD


# -------------------------------------------------------------
# Backend — Firebase Admin SDK
# Firebase Konsol → Proje Ayarları → Hizmet Hesapları
#   → "Yeni özel anahtar oluştur" → JSON dosyasını indirin
# -------------------------------------------------------------
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase Service Account JSON dosyasının HOST makinedeki tam yolu
# Windows örneği:   C:/Users/Lenovo/secrets/firebase-adminsdk.json
# Linux/Mac örneği: /home/user/secrets/firebase-adminsdk.json
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/your/firebase-adminsdk.json


# -------------------------------------------------------------
# Backend — Gemini API
# Google AI Studio → https://aistudio.google.com/app/apikey
# -------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key


# -------------------------------------------------------------
# Web UI — Firebase (Tarayıcı taraflı yapılandırma)
# Firebase Konsol → Proje Ayarları → Genel → Web Uygulamanız
# -------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080/api
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890


# -------------------------------------------------------------
# Port Ayarları (İsteğe bağlı — varsayılanlar yeterli)
# -------------------------------------------------------------
BACKEND_PORT=8080
WEB_PORT=80


# -------------------------------------------------------------
# pgAdmin (Opsiyonel — sadece --profile tools ile açılır)
# -------------------------------------------------------------
PGADMIN_EMAIL=admin@learnlanguage.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050


# -------------------------------------------------------------
# Rate Limiting (İsteğe bağlı — varsayılanlar yeterli)
# -------------------------------------------------------------
RATE_LIMIT_PERMIT=100
RATE_LIMIT_WINDOW=60
